{{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
    {{ form_row(form.title) }}
    {{ form_row(form.description) }}
    {{ form_row(form.location) }}
    {{ form_row(form.dateStart) }}
    {{ form_row(form.dateEnd) }}
    {{ form_row(form.price) }}
    {{ form_row(form.capacity) }}

    <div class="mb-3">
        {% if event is defined and event.imageName %}
            <label class="form-label fw-bold">Image actuelle</label>
            <div class="mb-2">
                <img src="/uploads/events/{{ event.imageName }}"
                     alt="Image actuelle"
                     class="rounded shadow-sm"
                     style="max-height: 200px; max-width: 100%; object-fit: cover;">
            </div>
        {% endif %}
        {{ form_row(form.imageFile) }}
    </div>

    <button class="btn btn-success mt-3 w-100">
        <i class="bi bi-save"></i> {{ button_label|default('Enregistrer') }}
    </button>
{{ form_end(form) }}