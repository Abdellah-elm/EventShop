{# templates/chatbot/_widget.html.twig #}
{# Include this in your base.html.twig: {{ include('chatbot/_widget.html.twig') }} #}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">

<style>
    :root {
        --cb-primary: #FF6B35;
        --cb-primary-light: #FF8C5A;
        --cb-dark: #1A1A2E;
        --cb-darker: #12121F;
        --cb-surface: #16213E;
        --cb-surface-light: #1C2A4A;
        --cb-text: #E8E8F0;
        --cb-text-muted: #8B8BA7;
        --cb-accent: #FFD166;
        --cb-glass: rgba(22, 33, 62, 0.85);
        --cb-border: rgba(255, 255, 255, 0.06);
        --cb-user-bg: linear-gradient(135deg, #FF6B35, #FF8C5A);
        --cb-bot-bg: rgba(255, 255, 255, 0.05);
        --cb-radius: 20px;
        --cb-shadow: 0 24px 80px rgba(0, 0, 0, 0.5), 0 0 1px rgba(255, 107, 53, 0.2);
    }

    /* ── Toggle Button ────────────────────────────── */
    .cb-toggle {
        position: fixed;
        bottom: 28px;
        right: 28px;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        z-index: 10000;
        background: var(--cb-dark);
        box-shadow: 0 8px 32px rgba(255, 107, 53, 0.3), 0 0 0 1px rgba(255, 107, 53, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        overflow: hidden;
    }
    .cb-toggle::before {
        content: '';
        position: absolute;
        inset: -1px;
        border-radius: 50%;
        padding: 2px;
        background: linear-gradient(135deg, var(--cb-primary), var(--cb-accent));
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0.6;
        transition: opacity 0.3s;
    }
    .cb-toggle:hover {
        transform: scale(1.08);
        box-shadow: 0 12px 40px rgba(255, 107, 53, 0.45), 0 0 0 1px rgba(255, 107, 53, 0.3);
    }
    .cb-toggle:hover::before { opacity: 1; }
    .cb-toggle svg {
        width: 28px;
        height: 28px;
        fill: none;
        stroke: var(--cb-primary);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .cb-toggle.active svg { transform: rotate(90deg); opacity: 0; }
    .cb-toggle .cb-close-icon {
        position: absolute;
        width: 22px;
        height: 22px;
        stroke: var(--cb-text);
        opacity: 0;
        transform: rotate(-90deg);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .cb-toggle.active .cb-close-icon { opacity: 1; transform: rotate(0deg); }

    /* ── Notification Dot ─────────────────────────── */
    .cb-dot {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 12px;
        height: 12px;
        background: var(--cb-accent);
        border-radius: 50%;
        border: 2px solid var(--cb-dark);
        animation: cb-pulse 2s ease-in-out infinite;
    }
    .cb-toggle.active .cb-dot { display: none; }
    @keyframes cb-pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.3); opacity: 0.7; }
    }

    /* ── Chat Window ──────────────────────────────── */
    .cb-window {
        position: fixed;
        bottom: 104px;
        right: 28px;
        width: 400px;
        max-height: 560px;
        background: var(--cb-darker);
        border-radius: var(--cb-radius);
        box-shadow: var(--cb-shadow);
        z-index: 9999;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
        border: 1px solid var(--cb-border);
        opacity: 0;
        visibility: hidden;
        transform: translateY(16px) scale(0.96);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .cb-window.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
    }

    /* ── Header ───────────────────────────────────── */
    .cb-header {
        padding: 20px 24px;
        background: var(--cb-glass);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--cb-border);
        display: flex;
        align-items: center;
        gap: 14px;
        position: relative;
        overflow: hidden;
    }
    .cb-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--cb-primary), var(--cb-accent), transparent);
        opacity: 0.5;
    }
    .cb-avatar {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--cb-primary), var(--cb-accent));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
        position: relative;
        box-shadow: 0 4px 16px rgba(255, 107, 53, 0.25);
    }
    .cb-avatar::after {
        content: '';
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 12px;
        height: 12px;
        background: #4ADE80;
        border-radius: 50%;
        border: 2px solid var(--cb-darker);
    }
    .cb-header-text h6 {
        margin: 0;
        font-size: 15px;
        font-weight: 700;
        color: var(--cb-text);
        letter-spacing: -0.01em;
    }
    .cb-header-text span {
        font-size: 12px;
        color: #4ADE80;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .cb-header-text span::before {
        content: '';
        width: 6px;
        height: 6px;
        background: #4ADE80;
        border-radius: 50%;
        display: inline-block;
    }

    /* ── Messages ─────────────────────────────────── */
    .cb-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        max-height: 360px;
        min-height: 220px;
        background:
            radial-gradient(ellipse at 20% 80%, rgba(255, 107, 53, 0.03), transparent 50%),
            radial-gradient(ellipse at 80% 20%, rgba(255, 209, 102, 0.03), transparent 50%),
            var(--cb-darker);
    }
    .cb-messages::-webkit-scrollbar { width: 5px; }
    .cb-messages::-webkit-scrollbar-track { background: transparent; }
    .cb-messages::-webkit-scrollbar-thumb { background: var(--cb-surface-light); border-radius: 10px; }

    .cb-msg {
        max-width: 82%;
        padding: 12px 16px;
        font-size: 13.5px;
        line-height: 1.6;
        word-wrap: break-word;
        animation: cb-fade-in 0.3s ease-out;
    }
    @keyframes cb-fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .cb-msg.bot {
        align-self: flex-start;
        background: var(--cb-bot-bg);
        color: var(--cb-text);
        border-radius: 4px 18px 18px 18px;
        border: 1px solid var(--cb-border);
    }
    .cb-msg.user {
        align-self: flex-end;
        background: var(--cb-user-bg);
        color: #fff;
        border-radius: 18px 4px 18px 18px;
        font-weight: 500;
        box-shadow: 0 4px 16px rgba(255, 107, 53, 0.2);
    }

    /* ── Typing Indicator ─────────────────────────── */
    .cb-typing {
        display: flex;
        gap: 5px;
        padding: 14px 18px;
        align-self: flex-start;
        background: var(--cb-bot-bg);
        border: 1px solid var(--cb-border);
        border-radius: 4px 18px 18px 18px;
        animation: cb-fade-in 0.3s ease-out;
    }
    .cb-typing span {
        width: 7px;
        height: 7px;
        background: var(--cb-text-muted);
        border-radius: 50%;
        animation: cb-bounce 1.4s ease-in-out infinite;
    }
    .cb-typing span:nth-child(2) { animation-delay: 0.15s; }
    .cb-typing span:nth-child(3) { animation-delay: 0.3s; }
    @keyframes cb-bounce {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
        30% { transform: translateY(-6px); opacity: 1; }
    }

    /* ── Quick Actions ────────────────────────────── */
    .cb-quick {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        padding: 4px 0 8px;
        animation: cb-fade-in 0.4s ease-out;
    }
    .cb-quick button {
        padding: 7px 14px;
        border-radius: 20px;
        border: 1px solid rgba(255, 107, 53, 0.25);
        background: rgba(255, 107, 53, 0.08);
        color: var(--cb-primary-light);
        font-size: 12px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.25s;
        white-space: nowrap;
    }
    .cb-quick button:hover {
        background: rgba(255, 107, 53, 0.18);
        border-color: var(--cb-primary);
        transform: translateY(-1px);
    }

    /* ── Input Area ───────────────────────────────── */
    .cb-input-area {
        padding: 16px 20px;
        border-top: 1px solid var(--cb-border);
        display: flex;
        gap: 10px;
        align-items: center;
        background: var(--cb-glass);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    .cb-input-area input {
        flex: 1;
        border: 1px solid var(--cb-border);
        border-radius: 14px;
        padding: 12px 18px;
        font-size: 13.5px;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        background: var(--cb-surface);
        color: var(--cb-text);
        transition: all 0.25s;
    }
    .cb-input-area input::placeholder { color: var(--cb-text-muted); }
    .cb-input-area input:focus {
        border-color: rgba(255, 107, 53, 0.4);
        box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.08);
    }
    .cb-send {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: none;
        background: var(--cb-user-bg);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.25s;
        flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(255, 107, 53, 0.25);
    }
    .cb-send:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(255, 107, 53, 0.35); }
    .cb-send:active { transform: scale(0.95); }
    .cb-send:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }
    .cb-send svg {
        width: 18px;
        height: 18px;
        fill: none;
        stroke: #fff;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    /* ── Branding ─────────────────────────────────── */
    .cb-brand {
        text-align: center;
        padding: 8px;
        font-size: 10px;
        color: var(--cb-text-muted);
        background: var(--cb-darker);
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* ── Responsive ───────────────────────────────── */
    @media (max-width: 480px) {
        .cb-window {
            width: calc(100vw - 24px);
            right: 12px;
            bottom: 96px;
            max-height: 70vh;
        }
        .cb-toggle { bottom: 20px; right: 20px; }
    }
</style>

<!-- Toggle Button -->
<button class="cb-toggle" id="cbToggle" aria-label="Ouvrir le chat">
    <svg viewBox="0 0 24 24">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <svg class="cb-close-icon" viewBox="0 0 24 24">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
    <div class="cb-dot"></div>
</button>

<!-- Chat Window -->
<div class="cb-window" id="cbWindow">
    <div class="cb-header">
        <div class="cb-avatar">🎫</div>
        <div class="cb-header-text">
            <h6>Event Shop Assistant</h6>
            <span>En ligne</span>
        </div>
    </div>

    <div class="cb-messages" id="cbMessages">
        <div class="cb-msg bot">
            Bienvenue sur Event Shop Maroc ! 🎉<br>
            Comment puis-je vous aider aujourd'hui ?
        </div>
        <div class="cb-quick" id="cbQuick">
            <button onclick="cbSendQuick('Quels événements sont disponibles ?')">📅 Événements</button>
            <button onclick="cbSendQuick('Comment réserver un billet ?')">🎟️ Réserver</button>
            <button onclick="cbSendQuick('Où télécharger mon billet ?')">📄 Mon billet</button>
        </div>
    </div>

    <div class="cb-input-area">
        <input type="text" id="cbInput" placeholder="Écrivez votre message..." autocomplete="off">
        <button class="cb-send" id="cbSend" aria-label="Envoyer">
            <svg viewBox="0 0 24 24">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
        </button>
    </div>

    <div class="cb-brand">Propulsé par IA — Event Shop Maroc</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('cbToggle');
    const win = document.getElementById('cbWindow');
    const messages = document.getElementById('cbMessages');
    const input = document.getElementById('cbInput');
    const sendBtn = document.getElementById('cbSend');
    let isOpen = false;

    toggle.addEventListener('click', () => {
        isOpen = !isOpen;
        win.classList.toggle('open', isOpen);
        toggle.classList.toggle('active', isOpen);
        if (isOpen) setTimeout(() => input.focus(), 300);
    });

    function addMsg(text, type) {
        const div = document.createElement('div');
        div.className = 'cb-msg ' + type;
        div.innerHTML = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
        return div;
    }

    function showTyping() {
        const div = document.createElement('div');
        div.className = 'cb-typing';
        div.id = 'cbTyping';
        div.innerHTML = '<span></span><span></span><span></span>';
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    }

    function hideTyping() {
        const el = document.getElementById('cbTyping');
        if (el) el.remove();
    }

    async function sendMessage(text) {
        if (!text) text = input.value.trim();
        if (!text) return;

        // Hide quick actions after first message
        const quick = document.getElementById('cbQuick');
        if (quick) quick.remove();

        addMsg(text, 'user');
        input.value = '';
        sendBtn.disabled = true;
        showTyping();

        try {
            const response = await fetch('/chatbot/ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });
            const data = await response.json();
            hideTyping();
            addMsg(data.reply, 'bot');
        } catch (err) {
            hideTyping();
            addMsg('Une erreur est survenue. Réessayez.', 'bot');
        }

        sendBtn.disabled = false;
        input.focus();
    }

    window.cbSendQuick = function(text) { sendMessage(text); };
    sendBtn.addEventListener('click', () => sendMessage());
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendMessage(); });
});
</script>